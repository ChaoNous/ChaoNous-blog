---
import { siteConfig } from "../config";
import { getDiaryList, getDiaryStats } from "../data/diary";
import MainGridLayout from "../layouts/MainGridLayout.astro";

if (!siteConfig.featurePages.diary) {
	return Astro.redirect("/404/");
}

const gameMoments = getDiaryList();
const gameStats = getDiaryStats();

function formatDate(dateString: string): string {
	return new Date(dateString).toLocaleDateString("zh-CN");
}
---

<MainGridLayout title="游戏" description="游戏动态与记录">
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<header class="mb-8">
				<h1
					class="text-3xl font-bold text-90 mb-3 relative
					before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
					before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
				>
					游戏
				</h1>
				<p class="text-60">记录我最近在玩什么</p>
			</header>

			<div class="mb-6 flex flex-wrap gap-2">
				<span class="btn-regular h-8 px-3 rounded-lg text-sm">总计 {gameStats.total} 条</span>
				<span class="btn-regular h-8 px-3 rounded-lg text-sm">含图片 {gameStats.hasImages} 条</span>
			</div>

			{
				gameMoments.length === 0 ? (
					<div class="text-center py-12">
						<h3 class="text-lg font-medium text-90 mb-2">暂无游戏记录</h3>
						<p class="text-60">添加数据后会在这里展示。</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{gameMoments.map((moment, index) => (
							<article class="game-card group bg-(--card-bg) rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-(--line-divider)">
								{moment.images && moment.images.length > 0 && (
									<div class="aspect-video overflow-hidden bg-black/5 dark:bg-white/5">
										<img
											src={moment.images[0]}
											alt="game cover"
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
											loading="lazy"
										/>
									</div>
								)}

								<div class="p-4">
									<p class="text-90 leading-relaxed mb-3 line-clamp-3">{moment.content}</p>

									{moment.tags && moment.tags.length > 0 && (
										<div class="flex flex-wrap gap-1 mb-3">
											{moment.tags.slice(0, 3).map((tag) => (
												<span class="btn-regular h-6 text-xs px-2 rounded-lg">{tag}</span>
											))}
										</div>
									)}

									<div class="flex items-center justify-between text-xs text-60">
										<span>条目 #{index + 1}</span>
										<time datetime={moment.date}>{formatDate(moment.date)}</time>
									</div>
								</div>
							</article>
						))}
					</div>
				)
			}
		</div>
	</div>
</MainGridLayout>

<style>
	.line-clamp-3 {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.game-card:hover {
		transform: translateY(-2px);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.game-card {
		animation: fadeInUp 0.3s ease-out;
	}
</style>
